{
  "name": "claude-session-manager",
  "version": "1.0.0",
  "description": "Web UI to browse, star, and clone Claude Code sessions",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npx vite --port 3001",
    "build": "cd client && npx vite build",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
